{
  "edges": {
    "gauss_blur_kernel": 21,
    "pixel_threshold": 40,
    "size_range": [
      100,
      1000000
    ]
  },
  "features": {
    "crosshair": {
      "fit_feature": false,
      "hough_threshold": 15,
      "max_line_gap": 5,
      "max_slope": 0.0,
      "min_length": 10
    },
    "ellipse": {
      "circularity_min": 0.6,
      "fit_feature": false,
      "size_range": [
        0,
        220000
      ]
    },
    "rectangle": {
      "fit_feature": false,
      "size_range": [
        0,
        220000
      ]
    }
  },
  "noise_handling": {
    "lower_percentile": 50,
    "normalize": true,
    "upper_percentile": 99,
    "winsor_percentile": 85
  }
}