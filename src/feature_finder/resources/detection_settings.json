{
  "edges": {
    "gauss_blur_kernel": 21,
    "normalize_noise": true,
    "pixel_threshold": 90,
    "size_range": [
      100,
      100000
    ]
  },
  "features": {
    "crosshair": {
      "fit_feature": false,
      "hough_threshold": 15,
      "max_line_gap": 5,
      "max_slope": 0.0,
      "min_length": 10
    },
    "ellipse": {
      "circularity_min": 0.6,
      "fit_feature": false,
      "size_range": [
        0,
        100000
      ]
    },
    "rectangle": {
      "fit_feature": false,
      "size_range": [
        0,
        100000
      ]
    }
  }
}